#!/bin/bash

if [ ! -d /sys/class/power_supply/BAT1 ]; then
    exit 0
fi

cap=$(cat /sys/class/power_supply/BAT1/capacity)
status=$(cat /sys/class/power_supply/BAT1/status)

if [ "$status" = "Charging" ] || [ "$status" = "Full" ]; then
    echo "ο΅Π $cap%"
    exit 0
fi

case $cap in
    100) echo "σΑ²Ö $cap%" ;;
    9*)  echo "σΑ¹Ι $cap%" ;;
    8*)  echo "σΑ²² $cap%" ;;
    7*)  echo "σΑ²¹ $cap%" ;;
    6*)  echo "σΑ²Ä $cap%" ;;
    5*)  echo "σΑ¹Ω $cap%" ;;
    4*)  echo "σΑ¹Ψ $cap%" ;;
    3*)  echo "σΑ¹Ϋ $cap%" ;;
    2*)  echo "σΑ¹Φ $cap%" ;;
    1*)  echo "σΑ¹Μ $cap%" ;;
    0*)  echo "σΑ¹Κ $cap%" ;;
esac
